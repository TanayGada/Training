<!--
    Hibernate Configuration File

    This XML configuration sets up the Hibernate ORM framework to connect with a PostgreSQL database.
    It defines properties such as the JDBC connection details, Hibernate behavior for schema generation,
    SQL query logging, and the mapping between Java classes and database tables.
-->
<hibernate-configuration xmlns="http://www.hibernate.org/xsd/orm/cfg">
    <session-factory>

        <!-- JDBC driver class for PostgreSQL -->
        <property name="hibernate.connection.driver_class">org.postgresql.Driver</property>

        <!-- JDBC URL to connect to the PostgreSQL database named 'test_db' running locally -->
        <property name="hibernate.connection.url">jdbc:postgresql://localhost:5432/test_db</property>

        <!-- Database username -->
        <property name="hibernate.connection.username">postgres</property>

        <!-- Database password -->
        <property name="hibernate.connection.password">tanay</property>

        <!--
            Schema generation strategy:
            - create: Drops and recreates the schema on every startup (useful for development/testing only)
            - update: Updates the schema to match the entity mappings without dropping data
            - validate: Validates the schema against entity mappings (no changes)
            - none: No action is taken with respect to the schema
        -->
        <property name="hibernate.hbm2ddl.auto">update</property>

        <!--
            Enables logging of SQL statements generated by Hibernate.
            Useful for debugging and understanding Hibernate's interaction with the database.
        -->
        <property name="hibernate.show_sql">true</property>

        <!--
            Registers the annotated entity class to be managed by Hibernate.
            Maps 'com.tanay.Student' Java class to its corresponding table in the database.
        -->
        <mapping class="com.tanay.Student"/>

    </session-factory>
</hibernate-configuration>